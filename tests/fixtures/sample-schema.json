{
  "engine": {
    "name": "video-pipeline",
    "version": "0.1.0",
    "schema_version": "0.1.0",
    "cli_entrypoint": "video-pipeline"
  },
  "steps": [
    {
      "id": "project",
      "label": "Project",
      "order": 10,
      "optional": false,
      "hint": "Scaffold the project folder + project.yml.",
      "help": "Creates the source/work/review/out/render layout and the project.yml that the later steps read defaults from. Always runs first."
    },
    {
      "id": "safezone",
      "label": "Safe Zone",
      "order": 20,
      "optional": true,
      "hint": "Derive the safe-zone spec from a template PNG.",
      "help": "Turns a design template (with the danger region marked) into the machine-readable safe-zone polygon that caption placement and QC use."
    },
    {
      "id": "reframe",
      "label": "Reframe",
      "order": 30,
      "optional": true,
      "hint": "Landscape -> portrait reframe.",
      "help": "Tracks the subject and crops the source to the target portrait frame. Skippable when the source is already in-aspect."
    },
    {
      "id": "roughcut",
      "label": "Rough Cut",
      "order": 40,
      "optional": true,
      "hint": "Propose cuts -> editable decision file.",
      "help": "Transcribes the clip and proposes a tightened cut (drops filler, false starts, dead air) as an editable decision file you can hand-tune before rendering."
    },
    {
      "id": "caption",
      "label": "Captions",
      "order": 50,
      "optional": true,
      "hint": "Transcribe + style burned-in captions.",
      "help": "Builds glossary-corrected word-timed cues, lets you edit the caption file, and renders the styled caption overlay layer."
    },
    {
      "id": "qc",
      "label": "Safe-Zone QC",
      "order": 60,
      "optional": true,
      "hint": "Check captions/faces against the danger zone.",
      "help": "Advisory check: flags protected elements intruding on the danger polygon and captions over the speaker's face. Advises, never blocks."
    },
    {
      "id": "composite",
      "label": "Composite",
      "order": 70,
      "optional": true,
      "hint": "Flatten the layers into one preview render.",
      "help": "Stacks the base and the caption/overlay layers into a single previewable video — the in-app preview of the assembled result and the guide track the editor handoffs carry on top. A review/handoff intermediate, not the final cut (that is yours, from your NLE)."
    },
    {
      "id": "output",
      "label": "Output / Packaging",
      "order": 80,
      "optional": true,
      "hint": "Package the project for your editor.",
      "help": "Editor handoffs: enable the target(s) you want and they run in the batch like any other step. Premiere (FCP7 XML) and Final Cut / Resolve (FCPXML) assemble the cut + caption + composite-guide tracks; CapCut gathers the rendered layers into a folder (it imports no project file)."
    }
  ],
  "tasks": [
    {
      "id": "project.init",
      "step": "project",
      "label": "Initialize project",
      "subcommand": "project-init",
      "optional": false,
      "consumes": [],
      "produces": [
        "base",
        "project"
      ],
      "io": [],
      "params": [
        {
          "key": "name",
          "type": "string",
          "arity": "positional",
          "control": "field",
          "ui": {
            "label": "Project name",
            "group": "Setup"
          },
          "order": 0,
          "required": true,
          "hint": "Project folder name.",
          "help": "Assembled to the convention \"YYYY-MM-DD <Token> Project - <Hook>\" from the fields below, so it always matches.",
          "compose": {
            "template": "{date} {token} Project - {hook}",
            "parts": [
              {
                "key": "date",
                "label": "Date",
                "control": "date",
                "default": "today"
              },
              {
                "key": "token",
                "label": "Token",
                "control": "dropdown",
                "options": [
                  "Reel",
                  "Story",
                  "Post"
                ],
                "default": "Reel",
                "hint": "Content-type token; part of the folder name and the render filename."
              },
              {
                "key": "hook",
                "label": "Hook",
                "control": "field",
                "hint": "A short description — becomes the render-file slug.",
                "placeholder": "short description"
              }
            ]
          }
        },
        {
          "key": "source",
          "type": "path",
          "arity": "value",
          "control": "picker",
          "ui": {
            "label": "Source video",
            "group": "Setup"
          },
          "flag": "--source",
          "hint": "Source video to ingest.",
          "help": "Pick the source clip. On run it is copied into the project — archived in source/ and seeded as the base layer (work/base.mp4) — so the reframe / rough-cut steps have their input. Browse or drag a file onto the field.",
          "path": {
            "kind": "file",
            "extensions": [
              "mp4",
              "mov",
              "m4v",
              "webm",
              "mkv",
              "avi"
            ]
          }
        },
        {
          "key": "identity",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Identity",
            "group": "Setup"
          },
          "flag": "--identity",
          "default": "dyson-hope",
          "required": true,
          "options": [
            "dyson-hope",
            "jason-cook-design",
            "sigil-zero"
          ],
          "hint": "Brand/identity id for styling defaults.",
          "help": "Selects the caption style + glossary set for this creator identity (e.g. a DH or SIGIL.ZERO identity).",
          "example": "--identity dyson-hope"
        },
        {
          "key": "profile",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Profile",
            "control": "dropdown",
            "group": "Output"
          },
          "flag": "--profile",
          "default": "reels-9x16",
          "required": true,
          "options": [
            "reels-9x16",
            "story-9x16",
            "feed-portrait-4x5",
            "feed-square-1x1",
            "feed-landscape-16x9"
          ],
          "hint": "Output aspect/dimensions preset.",
          "help": "The target frame. reels-9x16 (1080x1920) is the default for vertical Reels; the feed-* presets cover 4:5, 1:1, and 16:9. Drives crop math and safe-zone derivation.",
          "example": "--profile reels-9x16"
        },
        {
          "key": "root",
          "type": "path",
          "arity": "value",
          "control": "picker",
          "ui": {
            "label": "Projects root",
            "group": "Setup"
          },
          "flag": "--root",
          "hint": "Parent folder for projects.",
          "help": "Where the project folder is created. Defaults to ~/Video/Projects.",
          "path": {
            "kind": "directory"
          }
        },
        {
          "key": "no_trim_filler",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Preserve filler by default",
            "control": "toggle",
            "group": "Setup"
          },
          "flag": "--no-trim-filler",
          "default": false,
          "hint": "Seed the project to preserve filler.",
          "help": "Sets the project default so rough cut keeps audio continuity (no filler/false-start trimming) unless overridden per run."
        }
      ],
      "hint": "Scaffold a new project folder.",
      "help": "Creates the project layout and project.yml. The folder name encodes date/token/hook; identity and profile seed the project defaults."
    },
    {
      "id": "safezone.gen",
      "step": "safezone",
      "label": "Generate safe-zone spec",
      "subcommand": "safezone-gen",
      "optional": false,
      "consumes": [
        "project"
      ],
      "produces": [
        "safezone.def"
      ],
      "io": [
        {
          "artifact": "safezone.def",
          "role": "output",
          "via": "flag",
          "flag": "-o"
        }
      ],
      "params": [
        {
          "key": "template",
          "type": "path",
          "arity": "positional",
          "control": "picker",
          "ui": {
            "label": "Template PNG",
            "group": "Input"
          },
          "order": 0,
          "required": true,
          "hint": "Template PNG with the danger region marked.",
          "help": "The design template image. The marked region becomes the danger polygon (notch-aware).",
          "example": "template.png",
          "path": {
            "kind": "file",
            "extensions": [
              "png",
              "jpg",
              "jpeg",
              "webp"
            ]
          }
        },
        {
          "key": "profile",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Profile",
            "control": "dropdown",
            "group": "Output"
          },
          "flag": "--profile",
          "options": [
            "reels-9x16",
            "story-9x16",
            "feed-portrait-4x5",
            "feed-square-1x1",
            "feed-landscape-16x9"
          ],
          "hint": "Output aspect/dimensions preset.",
          "help": "The target frame. reels-9x16 (1080x1920) is the default for vertical Reels; the feed-* presets cover 4:5, 1:1, and 16:9. Drives crop math and safe-zone derivation.",
          "example": "--profile reels-9x16"
        },
        {
          "key": "key",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Region key",
            "control": "dropdown",
            "group": "Input"
          },
          "flag": "--key",
          "default": "auto",
          "options": [
            "auto",
            "alpha",
            "color"
          ],
          "hint": "How the danger region is marked.",
          "help": "auto detects alpha vs a key color; force alpha or color if detection guesses wrong."
        }
      ],
      "hint": "Derive the safe-zone polygon from a template PNG.",
      "help": "Reads a design template where the danger region is marked (by alpha or by a key color) and emits the safe-zone spec JSON consumed downstream."
    },
    {
      "id": "reframe",
      "step": "reframe",
      "label": "Reframe to portrait",
      "subcommand": "reframe",
      "optional": true,
      "consumes": [
        "base"
      ],
      "produces": [
        "base",
        "reframed"
      ],
      "io": [
        {
          "artifact": "base",
          "role": "input",
          "via": "positional",
          "order": 0
        },
        {
          "artifact": "base",
          "role": "output",
          "via": "flag",
          "flag": "-o"
        },
        {
          "artifact": "reframed",
          "role": "output",
          "via": "flag",
          "flag": "--reframed-out"
        }
      ],
      "params": [
        {
          "key": "profile",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Profile",
            "control": "dropdown",
            "group": "Output"
          },
          "flag": "--profile",
          "default": "reels-9x16",
          "options": [
            "reels-9x16",
            "story-9x16",
            "feed-portrait-4x5",
            "feed-square-1x1",
            "feed-landscape-16x9"
          ],
          "hint": "Output aspect/dimensions preset.",
          "help": "The target frame. reels-9x16 (1080x1920) is the default for vertical Reels; the feed-* presets cover 4:5, 1:1, and 16:9. Drives crop math and safe-zone derivation.",
          "example": "--profile reels-9x16"
        },
        {
          "key": "mode",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Crop mode",
            "control": "dropdown",
            "group": "Crop"
          },
          "flag": "--mode",
          "default": "static",
          "options": [
            "static",
            "dynamic"
          ],
          "hint": "Static hold vs subject-following crop.",
          "help": "static picks one crop window for the whole clip (predictable); dynamic pans to follow the subject (more motion)."
        },
        {
          "key": "tracker",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Tracker",
            "control": "dropdown",
            "group": "Crop"
          },
          "flag": "--tracker",
          "default": "opencv",
          "options": [
            "opencv",
            "mediapipe"
          ],
          "hint": "Subject detector backend.",
          "help": "opencv is dependency-light; mediapipe is the higher-quality daily-driver face/pose tracker."
        },
        {
          "key": "dry_run",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Dry run",
            "control": "toggle",
            "group": "Crop"
          },
          "flag": "--dry-run",
          "default": false,
          "hint": "Plan the crop without rendering.",
          "help": "Computes and prints the crop plan but writes no video — fast way to sanity-check tracking before a full render."
        }
      ],
      "hint": "Crop landscape source to the portrait frame.",
      "help": "Subject-tracking crop. Static holds one crop; dynamic follows the subject. Daily-driver path needs MediaPipe; --dry-run plans without rendering."
    },
    {
      "id": "roughcut",
      "step": "roughcut",
      "label": "Propose rough cut",
      "subcommand": "roughcut",
      "optional": true,
      "consumes": [
        "base"
      ],
      "produces": [
        "roughcut.def"
      ],
      "io": [
        {
          "artifact": "base",
          "role": "input",
          "via": "positional",
          "order": 0
        },
        {
          "artifact": "roughcut.def",
          "role": "output",
          "via": "flag",
          "flag": "-o"
        }
      ],
      "params": [
        {
          "key": "no_trim_filler",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Preserve filler",
            "control": "toggle",
            "group": "Cut"
          },
          "flag": "--no-trim-filler",
          "default": false,
          "hint": "Keep filler / preserve audio continuity.",
          "help": "Disables filler/dead-air trimming — one whole-clip KEEP, no speech edits. Use when continuity matters more than tightness."
        },
        {
          "key": "no_false_starts",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Keep false starts",
            "control": "toggle",
            "group": "Cut"
          },
          "flag": "--no-false-starts",
          "default": false,
          "hint": "Don't drop false starts."
        },
        {
          "key": "silence_gap",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Silence gap (s)",
            "control": "slider",
            "group": "Cut"
          },
          "flag": "--silence-gap",
          "default": 0.6,
          "min": 0.0,
          "max": 3.0,
          "step": 0.05,
          "hint": "Dead-air gap (s) that triggers a cut.",
          "help": "Silence longer than this (seconds) is treated as dead air and removed. Lower = tighter, more aggressive."
        },
        {
          "key": "pad_lead",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Lead pad (s)",
            "control": "slider",
            "group": "Padding"
          },
          "flag": "--pad-lead",
          "default": 0.06,
          "min": 0.0,
          "max": 0.5,
          "step": 0.01,
          "hint": "Lead padding before each kept segment (s).",
          "help": "Asymmetric cut padding. Small lead avoids clipping the first word's onset."
        },
        {
          "key": "pad_tail",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Tail pad (s)",
            "control": "slider",
            "group": "Padding"
          },
          "flag": "--pad-tail",
          "default": 0.15,
          "min": 0.0,
          "max": 0.5,
          "step": 0.01,
          "hint": "Tail padding after each kept segment (s).",
          "help": "Larger tail than lead avoids clipping word-ends (a real defect found in Phase-2 testing)."
        },
        {
          "key": "online",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Online model fetch",
            "control": "toggle",
            "group": "Transcription"
          },
          "flag": "--online",
          "default": false,
          "hint": "Allow model download (default offline).",
          "help": "mlx-whisper runs offline by default; --online permits a one-time model fetch."
        },
        {
          "key": "dry_run",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Dry run",
            "control": "toggle",
            "group": "Cut"
          },
          "flag": "--dry-run",
          "default": false,
          "hint": "Propose without rendering a cut."
        }
      ],
      "hint": "Transcribe + propose an editable cut decision file.",
      "help": "Produces the decision file (one scannable line per segment) you can hand-edit before rendering. Daily driver transcribes with mlx-whisper unless a --transcript is supplied."
    },
    {
      "id": "roughcut.render",
      "step": "roughcut",
      "label": "Render rough cut",
      "subcommand": "roughcut-render",
      "optional": true,
      "consumes": [
        "base",
        "roughcut.def"
      ],
      "produces": [
        "base"
      ],
      "io": [
        {
          "artifact": "roughcut.def",
          "role": "input",
          "via": "positional",
          "order": 0
        },
        {
          "artifact": "base",
          "role": "input",
          "via": "flag",
          "flag": "-i"
        },
        {
          "artifact": "base",
          "role": "output",
          "via": "flag",
          "flag": "-o"
        }
      ],
      "params": [
        {
          "key": "dry_run",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Dry run",
            "control": "toggle",
            "group": "Render"
          },
          "flag": "--dry-run",
          "default": false,
          "hint": "Show the trim/concat plan without rendering."
        }
      ],
      "hint": "Re-render the cut from the (edited) decision file.",
      "help": "Applies the decision file's KEEP segments to the source via ffmpeg trim/concat. Re-runnable after you hand-edit the decision file."
    },
    {
      "id": "caption.define",
      "step": "caption",
      "label": "Build caption file",
      "subcommand": "captions",
      "optional": true,
      "consumes": [
        "base",
        "safezone.def"
      ],
      "produces": [
        "caption.def"
      ],
      "io": [
        {
          "artifact": "base",
          "role": "input",
          "via": "positional",
          "order": 0
        },
        {
          "artifact": "caption.def",
          "role": "output",
          "via": "flag",
          "flag": "-o"
        },
        {
          "artifact": "safezone.def",
          "role": "input",
          "via": "flag",
          "flag": "--safezone"
        }
      ],
      "params": [
        {
          "key": "identity",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Identity",
            "group": "Setup"
          },
          "flag": "--identity",
          "default": "dyson-hope",
          "required": true,
          "options": [
            "dyson-hope",
            "jason-cook-design",
            "sigil-zero"
          ],
          "hint": "Identity for glossary + caption style.",
          "example": "--identity dyson-hope"
        },
        {
          "key": "profile",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Profile",
            "control": "dropdown",
            "group": "Output"
          },
          "flag": "--profile",
          "default": "reels-9x16",
          "options": [
            "reels-9x16",
            "story-9x16",
            "feed-portrait-4x5",
            "feed-square-1x1",
            "feed-landscape-16x9"
          ],
          "hint": "Output aspect/dimensions preset.",
          "help": "The target frame. reels-9x16 (1080x1920) is the default for vertical Reels; the feed-* presets cover 4:5, 1:1, and 16:9. Drives crop math and safe-zone derivation.",
          "example": "--profile reels-9x16"
        },
        {
          "key": "karaoke",
          "type": "bool",
          "arity": "switch",
          "control": "toggle",
          "ui": {
            "label": "Karaoke highlight",
            "control": "toggle",
            "group": "Style"
          },
          "flag": "--karaoke",
          "default": false,
          "hint": "Active-word highlight.",
          "help": "Karaoke mode highlights the currently-spoken word within each cue."
        },
        {
          "key": "font_family",
          "type": "enum",
          "arity": "value",
          "control": "dropdown",
          "ui": {
            "label": "Font",
            "control": "dropdown",
            "group": "Style"
          },
          "flag": "--font-family",
          "default": "Helvetica",
          "options": [
            "Archivo",
            "Inter",
            "IBM Plex Mono",
            "Helvetica",
            "Helvetica Neue",
            "Arial",
            "Arial Black",
            "Avenir Next",
            "Futura",
            "Gill Sans",
            "Impact",
            "Verdana",
            "Georgia",
            "Times New Roman",
            "Courier New",
            "Menlo",
            "Trebuchet MS"
          ],
          "hint": "Caption font family.",
          "help": "The font the captions render in. Curated allowlist (the same set the pipeline accepts); Remotion falls back to Helvetica until font loading lands (INI-088 Phase 4)."
        },
        {
          "key": "font_size",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Font size (px)",
            "control": "slider",
            "group": "Style"
          },
          "flag": "--font-size",
          "default": 96,
          "min": 24,
          "max": 240,
          "step": 2,
          "hint": "Caption font size (px at native height).",
          "help": "Pixel size at the profile's native height (reels = 1920px tall). Capped to a legible range at the Python boundary."
        },
        {
          "key": "fill_color",
          "type": "string",
          "arity": "value",
          "control": "field",
          "ui": {
            "label": "Fill color",
            "control": "field",
            "group": "Style"
          },
          "flag": "--fill-color",
          "default": "#FFFFFF",
          "hint": "Text fill color (hex).",
          "help": "Hex color of the caption text fill, e.g. #FFFFFF. A color-picker widget is deferred; enter hex for v1."
        },
        {
          "key": "stroke_color",
          "type": "string",
          "arity": "value",
          "control": "field",
          "ui": {
            "label": "Stroke color",
            "control": "field",
            "group": "Style"
          },
          "flag": "--stroke-color",
          "default": "#000000",
          "hint": "Text border/stroke color (hex).",
          "help": "Hex color of the caption text outline, e.g. #000000."
        },
        {
          "key": "stroke_width",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Stroke width (px)",
            "control": "slider",
            "group": "Style"
          },
          "flag": "--stroke-width",
          "default": 8,
          "min": 0,
          "max": 40,
          "step": 1,
          "hint": "Text border/stroke thickness (px).",
          "help": "Outline thickness in px; 0 disables the stroke. Capped at the Python boundary."
        },
        {
          "key": "min_words",
          "type": "number",
          "arity": "value",
          "control": "slider",
          "ui": {
            "label": "Min words / cue",
            "control": "slider",
            "group": "Timing"
          },
          "flag": "--min-words",
          "min": 1,
          "max": 8,
          "step": 1,
          "hint": "Minimum words per cue.",
